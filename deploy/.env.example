########################################
# LinTalk 服务基础配置
########################################

# 运行环境: development / production
NODE_ENV=production

# 服务端口 (容器内外映射由 docker-compose.yml 控制)
HTTP_PORT=9200
WS_PORT=9100
WEB_PORT=80

# 服务地址(域名): 前端构建后请求的 API / WS 地址
# 若你使用 Nginx 反向代理并启用 TLS, 推荐 https + wss
SERVICE_DOMAIN=lintalk.fun
VITE_HTTP_URL=https://lintalk.fun
VITE_WS_URL=wss://lintalk.fun
VITE_LINYU_VERSION=1.1.3

# 跨域允许来源 (建议与域名一致)
CORS_ORIGIN=https://lintalk.fun

# JWT 配置
JWT_SECRET=please-change-this-secret
JWT_EXPIRES_IN=7d

########################################
# 数据库配置
########################################

# 数据库类型: mysql / sqlite
DB_CLIENT=mysql

# sqlite 文件地址 (仅 DB_CLIENT=sqlite 时生效)
DB_FILE=./data/LinTalk.db

# 日志文件地址 (用于运维约定; 当前版本默认输出到控制台)
LOG_FILE=./logs/lintalk-server.log

# MySQL 配置 (DB_CLIENT=mysql 时生效)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=LinTalk
MYSQL_USER=lintalk
MYSQL_PASSWORD=please-change-db-password
MYSQL_ROOT_PASSWORD=please-change-root-password

########################################
# 聊天室业务配置
########################################

# 群聊密码
LINTALK_PASSWORD=linqia

# 限制用户数量
LINTALK_LIMIT=100

# 聊天室名称
LINTALK_NAME=LinTalk在线聊天室

# 数据过期时间(天)
LINTALK_EXPIRES=7

########################################
# 豆包配置
########################################

# 豆包 API Key
LINTALK_DOUBAO_API_KEY=

# 次数限制, 0-不限制
LINTALK_DOUBAO_COUNT_LIMIT=5

# 内容长度限制, 0-不限制
LINTALK_DOUBAO_LENGTH_LIMIT=50

# 使用的模型
LINTALK_DOUBAO_MODEL=doubao-seed-2-0-mini-260215

########################################
# 机器人账号配置
########################################
BOT_USER_ID=doubao
BOT_USER_NAME=豆包
